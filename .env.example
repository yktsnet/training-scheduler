# -----------------------------------------------------------------------------
# Training Scheduler Configuration
# -----------------------------------------------------------------------------

# アプリケーションの起動モード (デフォルトはデモモードです)
# 実際にチームで実運用する場合は、環境変数を false に設定してください。
# (false の場合、自動リセットや初期ダミーデータ🐶は投入されません)
DEMO_MODE=false

# 管理者画面のログイン用パスワード
# 実運用時は、セキュリティのため必ず独自の強力なパスワードに変更してください。
ADMIN_PASSWORD=your_secure_password